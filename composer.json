{
  "name": "ez-php/view",
  "version": "0.8.0",
  "description": "PHP template engine for the ez-php framework — layouts, sections, partials, and HTML escaping",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["view", "template", "php", "framework", "ez-php"],
  "homepage": "https://github.com/ez-php/view",
  "support": {
    "issues": "https://github.com/ez-php/view/issues",
    "source": "https://github.com/ez-php/view"
  },
  "require": {
    "php": "^8.5",
    "ez-php/contracts": "0.*"
  },
  "require-dev": {
    "ez-php/docker": "0.*",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\View\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
